# --- Origins: where untangle finds your repositories -------------------------
# Configure ONE OR MORE of the blocks below (they can be combined), or define
# richer origins (include/exclude filters, multiple instances) in
# config/untangle.yml — see config.example/untangle.yml.

# A GitLab instance (self-hosted or gitlab.com). Token scope: read_api + read_repository.
# GITLAB_URL=https://gitlab.example.com
# GITLAB_API_TOKEN=glpat-xxxxxxxxxxxx

# A GitHub organization or user. Token optional for public repos (rate limits apply).
# GITHUB_ORG=my-org
# GITHUB_USER=
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Any git hosts: a comma- or whitespace-separated list of clone URLs.
# GIT_REPOS=https://github.com/pallets/click.git,https://github.com/psf/requests.git
# GIT_REPOS_TOKEN=

# --- Analyzer ----------------------------------------------------------------
# Seconds between analyzer runs in compose (default: 86400 = daily; 0 = run once and exit).
# RUN_INTERVAL=86400
# Where the clone cache + analysis outputs live (default: ./data; /data in Docker).
# DATA_DIR=data
# Shallow clone depth; 0 = full clone (default: 1).
# CLONE_DEPTH=1
# Branch preference, highest first (default: develop,main,master).
# BRANCH_PRIORITY=develop,main,master
# Fail the run if more than this share of repos fail to clone (default: 0.15).
# MAX_CLONE_FAILURE_RATIO=0.15
# Override the location of the config YAMLs (default: <repo>/config).
# UNTANGLE_CONFIG_DIR=
# Also write a copy of the report here (the compose analyzer sets this to the
# shared volume; useful locally for serving the webapp without a container).
# WEBAPP_DATA_DIR=webapp/data

# --- Webapp ------------------------------------------------------------------
# Port the webapp listens on (default: 8080).
# WEB_PORT=8080
# Pull mode (alternative to the shared volume): URL of a published
# graph.json the webapp should fetch on start + on a timer.
# REPORT_URL=
# Token for REPORT_URL if it is private, and the header to send it in.
# REPORT_TOKEN=
# REPORT_TOKEN_HEADER=PRIVATE-TOKEN
# Seconds between background re-pulls in pull mode (default: 21600 = 6h).
# REFRESH_INTERVAL=21600
